// PropManage — Prisma schema (PostgreSQL).
//
// Conventions:
//  - Enum-like columns are `String`, constrained by TS const-maps in
//    `lib/enums.ts` & `lib/sa105.ts` (kept as the single source of truth +
//    label maps for the UI).
//  - Structured columns use native `Json` / scalar-list (`Int[]`/`String[]`).
//  - Money is stored as integer minor units (pence, `Int`) plus an ISO
//    `currency` code, to avoid floating-point drift.
//  - Audit timestamps `createdAt`/`updatedAt` on all mutable models; soft-delete
//    via `archivedAt` on key entities (Property, Tenancy).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & access
// ---------------------------------------------------------------------------

model User {
  id                        String    @id @default(cuid())
  firstName                 String?
  lastName                  String?
  email                     String    @unique
  emailVerified             DateTime?
  mobile                    String?
  mobileVerified            Boolean   @default(false)
  image                     String?
  passwordHash              String?
  role                      String    @default("owner") // UserRole: owner | assistant | accountant
  numberOfPropertiesManaged Int       @default(0)
  totpSecret                String? // base32 TOTP secret (set during enrolment)
  twoFactorEnabled          Boolean   @default(false)
  // First-run coachmark dismissals: { "<section>": "ok" | "off" }. null = none seen.
  coachmarkState            Json?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  authAccounts         AuthAccount[]
  sessions             Session[]
  memberships          Membership[]
  ownedEntities        Account[]                @relation("EntityPrincipal")
  ownerRecords         BeneficialOwner[]
  invitesSent          Membership[]             @relation("MembershipInviter")
  auditLogs            AuditLog[]
  uploadedFiles        FileObject[]
  emailVerifyTokens    EmailVerificationToken[]
  passwordResetTokens  PasswordResetToken[]
}

// Single-use, hashed token for email verification (sha256(raw) stored).
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Single-use, hashed token for password reset.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Auth.js OAuth account model — renamed from `Account` to free that name for the
// tenant. Inert today (credentials + JWT; no PrismaAdapter), kept for future OAuth.
model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// The top-level TENANT. Has many Users (via Membership), Portfolios, Properties.
// All financial data is scoped by accountId.
model Account {
  id              String   @id @default(cuid())
  displayName     String
  type            String   @default("INDIVIDUAL") // LandlordType: INDIVIDUAL | PORTFOLIO | LIMITED_COMPANY (kept for tax treatment)
  companyNumber   String?
  companyName     String?
  utr             String?
  vatRegistered   Boolean  @default(false)
  mtdEnrolled     Boolean  @default(false)
  principalUserId String
  // Subscription / trial + preferences
  subscriptionStatus String   @default("trialing") // SubscriptionStatus: trialing | active | past_due | canceled
  trialEndsAt        DateTime?
  firstTaxYear       String? // e.g. "2024-25"
  timeZone           String   @default("Europe/London")
  marketingOptIn     Boolean  @default(false)
  notificationPrefs  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  principal        User                 @relation("EntityPrincipal", fields: [principalUserId], references: [id])
  memberships      Membership[]
  portfolios       Portfolio[]
  companies        Company[]
  beneficialOwners BeneficialOwner[]
  properties       Property[]
  transactions     Transaction[]
  bankConnections  BankConnection[]
  documents        Document[]
  reminders        Reminder[]
  mortgages        Mortgage[]
  valuations       Valuation[]
  notes            Note[]
  files            FileObject[]
  taxStatements    TaxStatement[]
  mtdConnection    MtdConnection?
  auditLogs        AuditLog[]

  @@index([principalUserId])
}

// A grouping of properties within an account. Exactly one default 'Personal —
// Default' portfolio per account (enforced by a partial unique index in the
// migration). Property-less / untracked items fall into the default portfolio.
model Portfolio {
  id        String   @id @default(cuid())
  accountId String
  name      String
  type      String   @default("personal") // PortfolioType: personal | business
  isDefault Boolean  @default(false)
  companyId String? // optional; business portfolios only (enforced in app code)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account       Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  company       Company?          @relation(fields: [companyId], references: [id])
  properties    Property[]
  owners        BeneficialOwner[]
  taxStatements TaxStatement[]

  @@index([accountId])
  // Partial unique (one default per account) added via raw SQL in the migration:
  //   CREATE UNIQUE INDEX "Portfolio_one_default" ON "Portfolio"("accountId") WHERE "isDefault";
}

// Optional limited company linked to business portfolios (directors' loans,
// company tax).
model Company {
  id            String   @id @default(cuid())
  accountId     String
  name          String
  companyNumber String?
  utr           String?
  vatRegistered Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  account         Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  portfolios      Portfolio[]
  beneficialOwners BeneficialOwner[]

  @@index([accountId])
}

// User <-> Account link that powers multi-tenant + delegated access.
model Membership {
  id              String   @id @default(cuid())
  userId          String
  accountId String
  role            String   @default("VIEWER") // MembershipRole: OWNER | MANAGER | ACCOUNTANT | ASSISTANT | VIEWER
  scope           Json?    // e.g. {"propertyIds":[...]} ; null = full entity
  status          String   @default("ACTIVE") // MembershipStatus: INVITED | ACTIVE | REVOKED
  inviteEmail     String?
  inviteToken     String?  @unique
  invitedByUserId String?
  acceptedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity    Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  invitedBy User?          @relation("MembershipInviter", fields: [invitedByUserId], references: [id])

  @@unique([userId, accountId])
  @@index([accountId])
}

// An individual OR company that owns a percentage share of properties (and may
// be associated with a portfolio). May be an external party with no login.
model BeneficialOwner {
  id         String   @id @default(cuid())
  accountId  String
  type       String   @default("individual") // BeneficialOwnerType: individual | company
  legalName  String
  userId     String?
  companyId  String? // when type = company, may point at a Company
  portfolioId String? // optional "links to Portfolio" association
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  account       Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user          User?               @relation(fields: [userId], references: [id])
  company       Company?            @relation(fields: [companyId], references: [id])
  portfolio     Portfolio?          @relation(fields: [portfolioId], references: [id])
  ownerships    PropertyOwnership[]
  taxStatements TaxStatement[]

  @@index([accountId])
}

model AuditLog {
  id              String   @id @default(cuid())
  accountId String
  actorUserId     String?
  action          String
  targetType      String?
  targetId        String?
  metadata        Json?
  at              DateTime @default(now())

  entity Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  actor  User?          @relation(fields: [actorUserId], references: [id])

  @@index([accountId, at])
}

// ---------------------------------------------------------------------------
// Property & tenancy
// ---------------------------------------------------------------------------

model Property {
  id               String   @id @default(cuid())
  accountId        String
  portfolioId      String
  addressLine1     String
  addressLine2     String?
  city             String
  postcode         String
  country          String   @default("GB")
  propertyType     String   @default("FLAT") // PropertyType
  bedrooms         Int?
  purchaseDate     DateTime?
  purchasePricePence Int?
  currentValuePence  Int? // denormalised "current" valuation; Valuation[] is the history
  rentalIncomeAmountPence Int? // expected/headline rent for the property
  rentalIncomeFrequency   String @default("MONTHLY") // RentFrequency
  furnished        Boolean?
  isFHL            Boolean  @default(false)
  streetViewCameraPosition Json? // { heading, pitch, zoom, lat, lng }
  epcRating        String? // "A".."G"
  epcScore         Int? // 1..100
  epcExpiryDate    DateTime?
  archivedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // accountId is the tenant/security boundary; portfolioId is the grouping.
  entity          Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  portfolio       Portfolio           @relation(fields: [portfolioId], references: [id])
  ownerships      PropertyOwnership[]
  tenancies       Tenancy[]
  transactions    Transaction[]
  documents       Document[]
  reminders       Reminder[]
  mortgages       Mortgage[]
  valuations      Valuation[]
  notes           Note[]
  files           FileObject[]

  @@index([accountId])
  @@index([portfolioId])
}

// A mortgage secured on a property. Money as Int pence; rate as basis points.
model Mortgage {
  id                  String    @id @default(cuid())
  accountId           String
  propertyId          String
  lender              String
  productType         String    @default("FIXED") // MortgageProduct
  accountNumberMasked String?
  balancePence        Int
  monthlyPaymentPence Int
  interestRateBp      Int // 425 = 4.25%
  monthlyInterestPence Int?
  fixedUntil          DateTime?
  termMonths          Int?
  currency            String    @default("GBP")
  startDate           DateTime?
  archivedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  entity   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([propertyId])
}

// History of property valuations.
model Valuation {
  id          String   @id @default(cuid())
  accountId   String
  propertyId  String
  amountPence Int
  date        DateTime
  source      String? // "MANUAL" | "AVM" | "RICS" | ...
  currency    String   @default("GBP")
  createdAt   DateTime @default(now())

  entity   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([propertyId, date])
}

// Free-text note linked to a property or a tenant.
model Note {
  id          String   @id @default(cuid())
  accountId   String
  propertyId  String?
  tenantId    String?
  description String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entity   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  property Property?  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant   Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([propertyId])
  @@index([tenantId])
}

// Property *—* BeneficialOwner, carrying the ownership percentage (basis points).
model PropertyOwnership {
  id                    String   @id @default(cuid())
  propertyId            String
  beneficialOwnerId     String
  ownershipPercentageBp Int // basis points, 0..10000 (5000 = 50%)
  effectiveFrom         DateTime @default(now())
  effectiveTo           DateTime?
  createdAt             DateTime @default(now())

  property        Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  beneficialOwner BeneficialOwner @relation(fields: [beneficialOwnerId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([beneficialOwnerId])
}

model Tenancy {
  id            String   @id @default(cuid())
  propertyId    String
  status        String   @default("ACTIVE") // TenancyStatus
  startDate     DateTime
  endDate       DateTime?
  isPeriodic    Boolean  @default(false)
  rentPence     Int
  currency      String   @default("GBP") // ISO 4217
  rentFrequency String   @default("MONTHLY") // RentFrequency
  rentDueDay    Int? // day-of-month 1..31 (or day-of-week for weekly)
  nextPaymentDate DateTime?
  depositPence  Int?
  depositScheme String? // DepositScheme
  depositRef    String?
  arrearsState  String   @default("CURRENT") // TenancyArrearsState: CURRENT | ARREARS | CREDIT
  balancePence  Int      @default(0) // signed: negative = arrears, positive = credit
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property     Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenants      Tenant[]
  rentSchedule RentScheduleEntry[]
  transactions Transaction[]
  arrearsAlerts ArrearsAlert[]
  documents    Document[]
  reminders    Reminder[]

  @@index([propertyId])
  @@index([propertyId, archivedAt])
}

model Tenant {
  id           String  @id @default(cuid())
  tenancyId    String
  name         String
  email        String?
  phone        String?
  isLeadTenant Boolean @default(false)

  tenancy Tenancy @relation(fields: [tenancyId], references: [id], onDelete: Cascade)
  notes   Note[]

  @@index([tenancyId])
}

// ---------------------------------------------------------------------------
// Money: transactions & arrears
// ---------------------------------------------------------------------------

model Transaction {
  id               String   @id @default(cuid())
  accountId String
  propertyId       String?
  tenancyId        String?
  direction        String   // TxnDirection: INCOME | EXPENSE
  amountPence      Int      // always positive; sign implied by direction
  currency         String   @default("GBP") // ISO 4217
  date             DateTime
  rentDueDate      DateTime? // for rent txns: which rent period this satisfies
  description      String
  merchant         String?
  category         String?  // Sa105Category
  subcategory      String?
  notes            String?
  source           String   @default("MANUAL") // TxnSource: BANK_FEED | MANUAL | IMPORTED
  status           String   @default("UNRECONCILED") // TxnStatus (reconciled=RECONCILED, deactivated=EXCLUDED)
  bankTransactionId String? @unique
  splitParentId    String?
  attachmentFileId String?
  receiptDocumentId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  entity      Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  property    Property?        @relation(fields: [propertyId], references: [id])
  tenancy     Tenancy?         @relation(fields: [tenancyId], references: [id])
  bankTxn     BankTransaction? @relation(fields: [bankTransactionId], references: [id])
  splitParent Transaction?     @relation("TxnSplit", fields: [splitParentId], references: [id])
  splits      Transaction[]    @relation("TxnSplit")
  attachment  FileObject?      @relation(fields: [attachmentFileId], references: [id])
  receiptDocument Document?    @relation("TxnReceipt", fields: [receiptDocumentId], references: [id])

  @@index([accountId, date])
  @@index([propertyId])
  @@index([tenancyId])
}

// Expected rent obligations generated from a Tenancy; the basis of arrears.
model RentScheduleEntry {
  id            String   @id @default(cuid())
  tenancyId     String
  dueDate       DateTime
  expectedPence Int
  receivedPence Int      @default(0)
  status        String   @default("DUE") // RentStatus
  matchedTransactionIds String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenancy Tenancy @relation(fields: [tenancyId], references: [id], onDelete: Cascade)
  arrearsAlerts ArrearsAlert[]

  @@unique([tenancyId, dueDate])
  @@index([tenancyId])
}

model ArrearsAlert {
  id                  String   @id @default(cuid())
  tenancyId           String
  rentScheduleEntryId String
  shortfallPence      Int
  daysOverdue         Int
  firstDetectedAt     DateTime @default(now())
  resolvedAt          DateTime?

  tenancy   Tenancy           @relation(fields: [tenancyId], references: [id], onDelete: Cascade)
  scheduleEntry RentScheduleEntry @relation(fields: [rentScheduleEntryId], references: [id], onDelete: Cascade)

  @@index([tenancyId])
}

// ---------------------------------------------------------------------------
// Banking (mock-first)
// ---------------------------------------------------------------------------

model BankConnection {
  id                   String   @id @default(cuid())
  accountId     String
  provider             String   @default("mock")
  providerConnectionId String
  institutionName      String?
  status               String   @default("ACTIVE") // BankConnStatus
  accessTokenEnc       String?
  refreshTokenEnc      String?
  expiresAt            DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  entity   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accounts BankAccount[]

  @@index([accountId])
}

model BankAccount {
  id                   String   @id @default(cuid())
  bankConnectionId     String
  providerAccountId    String
  name                 String
  sortCode             String?
  accountNumberMasked  String?
  currency             String   @default("GBP")
  createdAt            DateTime @default(now())

  connection      BankConnection    @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)
  bankTransactions BankTransaction[]

  @@index([bankConnectionId])
}

model BankTransaction {
  id            String   @id @default(cuid())
  bankAccountId String
  providerTxnId String   @unique
  amountPence   Int
  date          DateTime
  description   String
  rawCategory   String?
  createdAt     DateTime @default(now())

  account     BankAccount  @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  matchedTxn  Transaction?

  @@index([bankAccountId, date])
}

// ---------------------------------------------------------------------------
// Compliance, dates & files
// ---------------------------------------------------------------------------

// A stored document: certificate, tenancy agreement, receipt, statement, etc.
// (generalised from the former ComplianceDocument). `expiryDate` is optional —
// only compliance certificates expire and drive reminders.
model Document {
  id                  String   @id @default(cuid())
  accountId           String
  propertyId          String?
  tenancyId           String?
  category            String   // DocumentCategory (compliance kinds + tenancy_agreement/receipt/...)
  issuedDate          DateTime?
  expiryDate          DateTime?
  reference           String?
  fileId              String?
  reminderOffsetsDays Int[]    @default([30, 14, 7, 1])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  entity        Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  property      Property?          @relation(fields: [propertyId], references: [id])
  tenancy       Tenancy?           @relation(fields: [tenancyId], references: [id])
  file          FileObject?        @relation(fields: [fileId], references: [id])
  reminders     DocumentReminder[]
  userReminders Reminder[]
  receiptTxns   Transaction[]      @relation("TxnReceipt")

  @@index([accountId])
  @@index([expiryDate])
}

// Materialised per-offset (30/14/7/1) expiry reminder rows for a Document, fired
// by the background job. Distinct from the user-facing `Reminder`.
model DocumentReminder {
  id         String   @id @default(cuid())
  documentId String
  fireOn     DateTime
  offsetDays Int
  status     String   @default("PENDING") // ReminderStatus: PENDING | SENT | DISMISSED
  sentAt     DateTime?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([fireOn, status])
}

// User-facing reminder / important date (open/completed). Replaces ImportantDate.
model Reminder {
  id          String   @id @default(cuid())
  accountId   String
  propertyId  String?
  tenancyId   String?
  documentId  String?
  name        String
  description String?
  dueDate     DateTime
  status      String   @default("OPEN") // ReminderState: OPEN | COMPLETED
  kind        String   @default("CUSTOM") // ImportantDateKind
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entity   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  property Property?  @relation(fields: [propertyId], references: [id])
  tenancy  Tenancy?   @relation(fields: [tenancyId], references: [id])
  document Document?  @relation(fields: [documentId], references: [id])

  @@index([accountId, dueDate])
  @@index([dueDate, status])
}

model FileObject {
  id               String   @id @default(cuid())
  accountId String
  propertyId       String?
  tenancyId        String?
  filename         String
  mimeType         String
  sizeBytes        Int
  storageKey       String
  uploadedByUserId String?
  createdAt        DateTime @default(now())

  entity         Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  property       Property?            @relation(fields: [propertyId], references: [id])
  uploadedBy     User?                @relation(fields: [uploadedByUserId], references: [id])
  documents      Document[]
  transactions   Transaction[]

  @@index([accountId])
}

// ---------------------------------------------------------------------------
// Tax & MTD
// ---------------------------------------------------------------------------

// Computed tax summary, scoped to an account and optionally a portfolio or a
// beneficial owner (pro-rata). Renamed from TaxYearEstimate.
model TaxStatement {
  id                        String   @id @default(cuid())
  accountId                 String
  portfolioId               String?
  beneficialOwnerId         String?
  taxYearStart              DateTime // always 6 Apr
  taxYearLabel              String   // e.g. "2025-26"
  computedAt                DateTime @default(now())
  boxBreakdown              Json     // { box -> pence }
  currency                  String   @default("GBP") // ISO 4217
  totalIncomePence          Int
  totalAllowableExpensesPence Int
  financeCostsPence         Int      @default(0)
  financeCostTaxReductionPence Int   @default(0)
  propertyAllowanceUsedPence Int     @default(0)
  taxableProfitPence        Int
  estimatedTaxPence         Int?

  entity          Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  portfolio       Portfolio?       @relation(fields: [portfolioId], references: [id])
  beneficialOwner BeneficialOwner? @relation(fields: [beneficialOwnerId], references: [id])

  @@unique([accountId, portfolioId, beneficialOwnerId, taxYearStart])
  @@index([accountId])
}

model MtdConnection {
  id                     String   @id @default(cuid())
  accountId       String   @unique
  hmrcUserId             String?
  accessTokenEnc         String?
  refreshTokenEnc        String?
  expiresAt              DateTime?
  businessIncomeSourceId String?
  status                 String   @default("NOT_CONNECTED") // MtdStatus
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  entity      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  obligations MtdObligation[]
  submissions MtdSubmission[]
}

model MtdObligation {
  id              String   @id @default(cuid())
  mtdConnectionId String
  periodKey       String
  startDate       DateTime
  endDate         DateTime
  dueDate         DateTime
  type            String   @default("QUARTERLY_UPDATE") // ObligationType
  status          String   @default("OPEN") // ObligationStatus
  createdAt       DateTime @default(now())

  connection  MtdConnection   @relation(fields: [mtdConnectionId], references: [id], onDelete: Cascade)
  submissions MtdSubmission[]

  @@unique([mtdConnectionId, periodKey])
}

model MtdSubmission {
  id              String   @id @default(cuid())
  mtdConnectionId String
  obligationId    String?
  type            String   // SubmissionType
  periodKey       String?
  taxYearLabel    String?
  payload         Json
  status          String   @default("PENDING") // SubmissionStatus
  hmrcReceiptId   String?
  submittedAt     DateTime?
  errorJson       Json?
  createdAt       DateTime @default(now())

  connection MtdConnection  @relation(fields: [mtdConnectionId], references: [id], onDelete: Cascade)
  obligation MtdObligation? @relation(fields: [obligationId], references: [id])

  @@index([mtdConnectionId])
}
