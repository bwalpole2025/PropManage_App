# Copy to .env and fill in. Local dev defaults work with local Postgres + mocks.
# For the Vercel PRODUCTION environment, set the real values below; the build runs
# `npm run check-env` (scripts/check-env.mjs) and FAILS if a critical one is missing.

# --- Supabase — Postgres  [prod] --------------------------------------------
# DATABASE_URL: the Postgres connection string. The Vercel build runs
#   `prisma migrate deploy`, so this MUST be a migration-capable connection —
#   use Supabase's Session-mode connection string (or the Direct connection),
#   NOT the Transaction pooler (:6543), which can't run migrations.
#   Supabase → Project → Settings → Database → Connection string.
DATABASE_URL="postgresql://localhost:5433/propmanage?schema=public"
AUTH_SECRET="generate-with: npx auth secret"
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# --- Closed beta gatekeeper ------------------------------------------------
# During the closed beta, ONLY these emails may sign in at the hidden
# /beta-access route (comma-separated). Anyone else is refused at login and gets
# a 403 from the middleware. The public landing page shows a "coming soon"
# banner and self-registration is disabled. Leave empty to lock everyone out.
BETA_TESTER_EMAILS="tester1@example.com,tester2@example.com,tester3@example.com"

SERVICE_MODE="mock"
BANK_FEED_PROVIDER="mock"
HMRC_MTD_MODE="mock"

STORAGE_DRIVER="mock"
FILE_STORAGE_DIR="./storage"
S3_ENDPOINT=""
S3_REGION="eu-west-2"
S3_BUCKET="propmanage-files"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"

QUEUE_DRIVER="memory"
REDIS_URL=""

# Email transport. EMAIL_DRIVER = mock | smtp | resend.
#   • Leave as "mock" for local dev (logs to console + in-memory outbox).
#   • Set RESEND_API_KEY (below) to auto-select Resend, or force it with
#     EMAIL_DRIVER="resend". EMAIL_FROM must be a domain verified in Resend.
#   • In production EMAIL_FROM must use the verified production domain
#     (propmanage.app), e.g. "PropManage <no-reply@propmanage.app>". The Resend
#     SDK helpers in lib/email/emailService.ts default to that domain.
EMAIL_DRIVER="mock"
SMTP_URL=""
EMAIL_FROM="PropManage <no-reply@propmanage.local>"
SUPPORT_EMAIL="support@propmanage.local"

# Resend (https://resend.com) — transactional email for reminders + reports.
# Create a key at https://resend.com/api-keys and verify your sending domain.
RESEND_API_KEY=""

# Help area — point these at your real booking page / help centre (client-exposed).
NEXT_PUBLIC_TUTORIAL_BOOKING_URL="https://cal.com/propmanage/live-tutorial"
NEXT_PUBLIC_HELP_CENTER_URL="https://help.propmanage.app"

# Token-at-rest encryption key (required in production with a real bank/HMRC provider).
TOKEN_ENC_KEY=""

# --- TrueLayer open-banking bank feed -------------------------------------
# Set BANK_FEED_PROVIDER=truelayer (above) AND NODE_ENV=production to use the
# real feed; dev/CI always use the in-memory mock. TOKEN_ENC_KEY is required.
TRUELAYER_CLIENT_ID=""
TRUELAYER_CLIENT_SECRET=""
TRUELAYER_ENV="sandbox"                # sandbox | live
# Must EXACTLY match a redirect URI registered in the TrueLayer console:
TRUELAYER_REDIRECT_URI="http://localhost:3000/api/banking/truelayer/callback"
# Providers to offer at consent (sandbox ships a mock bank: uk-cs-mock):
TRUELAYER_PROVIDERS="uk-cs-mock uk-ob-all uk-oauth-all"
# JWKS used to verify inbound webhook signatures (default is TrueLayer's live set):
TRUELAYER_WEBHOOK_JWKS_URL="https://webhooks.truelayer.com/.well-known/jwks"
# --- Payments API (live) — request signing -------------------------------
# For the Payments API (payments/mandates), set TRUELAYER_ENV="live" above and
# provide the EC P-521 signing key whose PUBLIC half is uploaded in the console.
# The kid is returned by the console; the private key is PEM (use \n escapes, or
# a base64-encoded PEM). Keep this in a secret manager, never in the repo.
TRUELAYER_KID=""
TRUELAYER_PRIVATE_KEY=""

HMRC_CLIENT_ID=""
HMRC_CLIENT_SECRET=""
HMRC_BASE_URL="https://test-api.service.hmrc.gov.uk"
