# Copy to .env and fill in. Local dev defaults work with local Postgres + mocks.
DATABASE_URL="postgresql://localhost:5433/propmanage?schema=public"
AUTH_SECRET="generate-with: npx auth secret"
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

SERVICE_MODE="mock"
BANK_FEED_PROVIDER="mock"
HMRC_MTD_MODE="mock"

STORAGE_DRIVER="mock"
FILE_STORAGE_DIR="./storage"
S3_ENDPOINT=""
S3_REGION="eu-west-2"
S3_BUCKET="propmanage-files"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"

QUEUE_DRIVER="memory"
REDIS_URL=""

EMAIL_DRIVER="mock"
SMTP_URL=""
EMAIL_FROM="PropManage <no-reply@propmanage.local>"

TRUELAYER_CLIENT_ID=""
TRUELAYER_CLIENT_SECRET=""
HMRC_CLIENT_ID=""
HMRC_CLIENT_SECRET=""
HMRC_BASE_URL="https://test-api.service.hmrc.gov.uk"
